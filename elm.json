{
    "type": "package",
    "name": "eco/kernel",
    "summary": "Kernel IO operations for the Eco compiler",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Eco.Console",
        "Eco.Crash",
        "Eco.Env",
        "Eco.File",
        "Eco.Http",
        "Eco.Http.Error",
        "Eco.IO.Error",
        "Eco.MVar",
        "Eco.NativeDriver",
        "Eco.Process",
        "Eco.Process.Error",
        "Eco.Runtime"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.1.3 <= v < 2.0.0",
        "elm/bytes": "1.0.0 <= v < 2.0.0",
        "elm/time": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {}
